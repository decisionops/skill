{
  "version": 1,
  "defaults": {
    "skill_name": "decision-ops",
    "mcp_server_name": "decision-ops-mcp",
    "mcp_server_url": "https://api.aidecisionops.com/mcp"
  },
  "platforms": [
    {
      "id": "antigravity",
      "display_name": "Antigravity",
      "platform_definition": "platforms/antigravity.toml",
      "skill": {
        "supported": true,
        "install_path_template": "~/.antigravity/skills/{skill_name}",
        "install_path_env": null
      },
      "mcp": {
        "supported": true,
        "scope": "user",
        "config_path_template": "{ANTIGRAVITY_MCP_CONFIG_PATH}",
        "config_path_env": "ANTIGRAVITY_MCP_CONFIG_PATH",
        "format": "json_map",
        "root_key": "mcpServers"
      },
      "manifest": {
        "supported": true,
        "path_template": ".decisionops/manifest.toml"
      },
      "auth": {
        "mode": "browser_oauth",
        "instructions": [
          "Open Antigravity → Agent panel → MCP Store and confirm `decision-ops-mcp` is enabled.",
          "Invoke any Decision Ops MCP tool in chat; Antigravity will open a browser for OAuth the first time.",
          "To reset a stale session, toggle `decision-ops-mcp` off and back on in the MCP Store (no CLI trigger exists).",
          "Known limitation: Antigravity does not fully implement the MCP OAuth 2.1 / RFC 9728 spec; servers that require dynamic client registration may not auth."
        ]
      },
      "default_server": {
        "name": "decision-ops-mcp",
        "url": "https://api.aidecisionops.com/mcp"
      },
      "cli_install_template": "dops install antigravity --repo-path {repo_path} --org-id {org_id} --project-id {project_id} --repo-ref {repo_ref}"
    },
    {
      "id": "claude-code",
      "display_name": "Claude Code",
      "platform_definition": "platforms/claude-code.toml",
      "skill": {
        "supported": true,
        "install_path_template": "~/.claude/skills/{skill_name}",
        "install_path_env": null
      },
      "mcp": {
        "supported": true,
        "scope": "project",
        "config_path_template": "{repo_path}/.mcp.json",
        "config_path_env": "CLAUDE_MCP_CONFIG_PATH",
        "format": "json_map",
        "root_key": "mcpServers"
      },
      "manifest": {
        "supported": true,
        "path_template": ".decisionops/manifest.toml"
      },
      "auth": {
        "mode": "browser_oauth",
        "instructions": [
          "Inside Claude Code, run the `/mcp` slash command.",
          "Select `decision-ops-mcp` from the list, then choose `Authenticate`.",
          "Approve the consent screen at auth.aidecisionops.com in your browser.",
          "To clear a stale session, run `/mcp` and choose `Clear authentication` for the same server before retrying."
        ]
      },
      "default_server": {
        "name": "decision-ops-mcp",
        "url": "https://api.aidecisionops.com/mcp"
      },
      "cli_install_template": "dops install claude-code --repo-path {repo_path} --org-id {org_id} --project-id {project_id} --repo-ref {repo_ref}"
    },
    {
      "id": "codex",
      "display_name": "Codex",
      "platform_definition": "platforms/codex.toml",
      "skill": {
        "supported": true,
        "install_path_template": "~/.codex/skills/{skill_name}",
        "install_path_env": null
      },
      "mcp": {
        "supported": true,
        "scope": "user",
        "config_path_template": "~/.codex/config.toml",
        "config_path_env": "CODEX_CONFIG_PATH",
        "format": "codex_toml",
        "root_key": null
      },
      "manifest": {
        "supported": true,
        "path_template": ".decisionops/manifest.toml"
      },
      "auth": {
        "mode": "browser_oauth",
        "instructions": [
          "Run `codex mcp login decision-ops-mcp` to trigger the OAuth flow in your browser.",
          "Approve the consent screen at auth.aidecisionops.com.",
          "If authentication is already cached against a stale URL, run `codex mcp logout decision-ops-mcp` first."
        ]
      },
      "default_server": {
        "name": "decision-ops-mcp",
        "url": "https://api.aidecisionops.com/mcp"
      },
      "cli_install_template": "dops install codex --repo-path {repo_path} --org-id {org_id} --project-id {project_id} --repo-ref {repo_ref}"
    },
    {
      "id": "cursor",
      "display_name": "Cursor",
      "platform_definition": "platforms/cursor.toml",
      "skill": {
        "supported": true,
        "install_path_template": "~/.cursor/skills/{skill_name}",
        "install_path_env": null
      },
      "mcp": {
        "supported": true,
        "scope": "project",
        "config_path_template": "{repo_path}/.cursor/mcp.json",
        "config_path_env": "CURSOR_MCP_CONFIG_PATH",
        "format": "json_map",
        "root_key": "mcpServers"
      },
      "manifest": {
        "supported": true,
        "path_template": ".decisionops/manifest.toml"
      },
      "auth": {
        "mode": "browser_oauth",
        "instructions": [
          "Open Cursor Settings → Tools & MCP and verify `decision-ops-mcp` is enabled.",
          "Invoke any Decision Ops MCP tool to trigger the browser OAuth flow; approve the consent screen at auth.aidecisionops.com.",
          "If a stale token blocks login: open Command Palette (Cmd/Ctrl+Shift+P) → `Clear All MCP Tokens`, then toggle `decision-ops-mcp` off and back on. Cursor has no per-server clear yet (forum request open)."
        ]
      },
      "default_server": {
        "name": "decision-ops-mcp",
        "url": "https://api.aidecisionops.com/mcp"
      },
      "cli_install_template": "dops install cursor --repo-path {repo_path} --org-id {org_id} --project-id {project_id} --repo-ref {repo_ref}"
    },
    {
      "id": "vscode",
      "display_name": "VS Code",
      "platform_definition": "platforms/vscode.toml",
      "skill": {
        "supported": false,
        "install_path_template": null,
        "install_path_env": null
      },
      "mcp": {
        "supported": true,
        "scope": "project",
        "config_path_template": "{repo_path}/.vscode/mcp.json",
        "config_path_env": "VSCODE_MCP_CONFIG_PATH",
        "format": "json_map",
        "root_key": "servers"
      },
      "manifest": {
        "supported": true,
        "path_template": ".decisionops/manifest.toml"
      },
      "auth": {
        "mode": "browser_oauth",
        "instructions": [
          "Open Command Palette (Cmd/Ctrl+Shift+P) → `MCP: List Servers`, select `decision-ops-mcp`, then `Start Server` to trigger OAuth.",
          "Approve the consent screen at auth.aidecisionops.com in your browser.",
          "To clear a stale session, select `decision-ops-mcp` in `MCP: List Servers` → `Disconnect Account` before starting the server again.",
          "Requires VS Code 1.102+ (built-in MCP). Account-level management: Accounts menu → `Manage Trusted MCP Servers`."
        ]
      },
      "default_server": {
        "name": "decision-ops-mcp",
        "url": "https://api.aidecisionops.com/mcp"
      },
      "cli_install_template": "dops install vscode --repo-path {repo_path} --org-id {org_id} --project-id {project_id} --repo-ref {repo_ref}"
    }
  ]
}
